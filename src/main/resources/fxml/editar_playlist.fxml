<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.audioarch.ui.controller.EditarPlaylistController"
           style="-fx-background-color: transparent; -fx-padding: 25;">
           
    <VBox stylesheets="@../css/login.css"
          style="-fx-background-color: #0f0f0f; -fx-padding: 35; -fx-border-color: #fe7faa; -fx-border-width: 1.5; -fx-border-radius: 25; -fx-background-radius: 25;"
          prefWidth="500" spacing="22">
        
        <effect>
            <DropShadow color="#fe7faa88" radius="30" spread="0.1" />
        </effect>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <Label text="Editar Detalles de Playlist" styleClass="logo" style="-fx-font-size: 24px; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#cerrar" style="-fx-background-color: transparent; -fx-text-fill: #aaa; -fx-font-size: 16px; -fx-cursor: hand;"/>
        </HBox>

        <!-- Foto de Portada -->
        <HBox alignment="CENTER" spacing="20">
            <VBox alignment="CENTER">
                <!-- Neon ring around image -->
                <StackPane style="-fx-border-color: #fe7faa; -fx-border-width: 2; -fx-border-radius: 12; -fx-padding: 4;">
                    <ImageView fx:id="imgPreview" fitHeight="80" fitWidth="80" preserveRatio="false">
                         <clip>
                             <Rectangle width="80" height="80" arcWidth="10" arcHeight="10" />
                         </clip>
                    </ImageView>
                </StackPane>
            </VBox>
            <VBox spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                 <Label text="Foto de Portada (URL o Local)" styleClass="label" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
                 <HBox spacing="10">
                     <TextField fx:id="txtFoto" promptText="URL o archivo..." styleClass="text-field" HBox.hgrow="ALWAYS"/>
                     <Button text="Explorar..." onAction="#seleccionarArchivo" styleClass="button" style="-fx-padding: 10 15;"/>
                 </HBox>
            </VBox>
        </HBox>

        <VBox spacing="8">
            <Label text="Nombre" styleClass="label" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
            <TextField fx:id="txtNombre" styleClass="text-field" promptText="Nombre de la playlist..."/>
        </VBox>

        <VBox spacing="8">
            <Label text="Descripción" styleClass="label" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
            <TextArea fx:id="txtDescripcion" prefHeight="100" wrapText="true" styleClass="text-area-neon" promptText="Descripción de tu playlist..."/>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 15 0 0 0;">
            <Button text="Cancelar" onAction="#cerrar" style="-fx-background-color: transparent; -fx-text-fill: #777; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button text="Guardar Cambios" onAction="#guardar" styleClass="button-principal" style="-fx-padding: 10 25; -fx-text-fill: white;"/>
        </HBox>
    </VBox>
</StackPane>
