<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.audioarch.ui.controller.ReseñaController"
           style="-fx-background-color: transparent; -fx-padding: 20;">
    
    <VBox spacing="20" style="-fx-background-color: #0f0f0f; -fx-padding: 30; -fx-border-color: #fe7faa; -fx-border-width: 1.5; -fx-border-radius: 25; -fx-background-radius: 25;"
          prefWidth="500">
        
        <effect>
            <DropShadow color="#fe7faa" radius="30" spread="0.1" />
        </effect>

        <HBox spacing="25" alignment="CENTER_LEFT">
            <ImageView fx:id="imgPortada" fitHeight="130" fitWidth="130" preserveRatio="true">
                <!-- El efecto se aplica en el controlador (aplicarEfectoVinilo) -->
            </ImageView>
            <VBox spacing="5" alignment="CENTER_LEFT">
                <Label fx:id="lblTipo" text="CANCION" style="-fx-text-fill: #fe7faa; -fx-font-size: 11; -fx-font-weight: bold; -fx-letter-spacing: 2;"/>
                <Label fx:id="lblTitulo" text="Nombre" style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold;"/>
                <Label fx:id="lblDetalle" text="Artista" style="-fx-text-fill: #aaaaaa; -fx-font-size: 15;"/>
                <Label fx:id="lblInfoExtra" text="Info" style="-fx-text-fill: #666666; -fx-font-size: 12;"/>
            </VBox>
        </HBox>

        <Separator opacity="0.1" style="-fx-background-color: white;"/>

        <VBox spacing="10" alignment="CENTER">
            <Label text="¿Qué nota le das?" style="-fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold;"/>
            <HBox fx:id="containerEstrellas" spacing="8" alignment="CENTER">
                <Label text="★" style="-fx-text-fill: #1a1a1a; -fx-font-size: 40; -fx-cursor: hand;"/>
                <Label text="★" style="-fx-text-fill: #1a1a1a; -fx-font-size: 40; -fx-cursor: hand;"/>
                <Label text="★" style="-fx-text-fill: #1a1a1a; -fx-font-size: 40; -fx-cursor: hand;"/>
                <Label text="★" style="-fx-text-fill: #1a1a1a; -fx-font-size: 40; -fx-cursor: hand;"/>
                <Label text="★" style="-fx-text-fill: #1a1a1a; -fx-font-size: 40; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <VBox spacing="10">
            <Label text="Tu reseña (opcional):" style="-fx-text-fill: white; -fx-font-size: 13;"/>
            <TextArea fx:id="txtReview" prefHeight="100" promptText="Escribe aquí tu opinión..."
                      styleClass="text-area-neon"
                      stylesheets="@../css/login.css"
                      wrapText="true"/>
        </VBox>

        <HBox spacing="35" alignment="CENTER">
            <Button text="CANCELAR" onAction="#cerrar"
                    style="-fx-background-color: transparent; -fx-text-fill: #777; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 13;"/>

            <Button text="GUARDAR" onAction="#guardar"
                    style="-fx-background-color: linear-gradient(to right, #fe7faa, #a11f5c); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 12 40; -fx-cursor: hand; -fx-font-size: 14;">
                <effect>
                    <DropShadow color="#fe7faa88" radius="20" />
                </effect>
            </Button>
        </HBox>
    </VBox>
</StackPane>
